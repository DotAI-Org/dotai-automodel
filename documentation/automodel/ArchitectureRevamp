│ File: app/chat/handler.py                                                                                                                                                           │
│                                                                                                                                                                                     │
│ async def handle_message(session_id: str, text: str, agent_state: AgentState) -> str:                                                                                               │
│                                                                                                                                                                                     │
│ The handler sends the user message to the LLM with:                                                                                                                                 │
│ - Conversation history                                                                                                                                                              │
│ - Current agent state (iteration, features, metrics)                                                                                                                                │
│ - Available commands                                                                                                                                                                │
│                                                                                                                                                                                     │
│ The LLM classifies the message as:                                                                                                                                                  │
│ 1. Command: Modify agent state (remove feature, add feature, change model, change criteria)                                                                                         │
│ 2. Question: Answer from pipeline context (what does this feature mean, why was this removed)                                                                                       │
│ 3. Approval: User accepts current champion                                                                                                                                          │
│                                                                                                                                                                                     │
│ For commands, the handler modifies agent_state.user_overrides which the agent loop picks up.                                                                                        │
│                                                                                                                                                                                     │
│ Command Schema                                                                                                                                                                      │
│                                                                                                                                                                                     │
│ class LLMChatOutput(BaseModel):                                                                                                                                                     │
│     intent: str              # "command" | "question" | "approval"                                                                                                                  │
│     response_text: str       # text to show user                                                                                                                                    │
│     command: str | None      # "remove_feature" | "add_feature" | "change_criteria" | ...                                                                                           │
│     command_params: dict | None                                                                                                                                                     │
