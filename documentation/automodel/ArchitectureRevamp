│ │     Model     │ Library │                           Key Hyperparameters                           │                                                                               │
│ ├───────────────┼─────────┼─────────────────────────────────────────────────────────────────────────┤                                                                               │
│ │ XGBoost       │ xgboost │ n_estimators=100, max_depth=5, learning_rate=0.1, scale_pos_weight=auto │                                                                               │
│ ├───────────────┼─────────┼─────────────────────────────────────────────────────────────────────────┤                                                                               │
│ │ Random Forest │ sklearn │ n_estimators=100, max_depth=8, class_weight="balanced"                  │                                                                               │
│ └───────────────┴─────────┴─────────────────────────────────────────────────────────────────────────┘                                                                               │
│ Interface                                                                                                                                                                           │
│                                                                                                                                                                                     │
│ @dataclass                                                                                                                                                                          │
│ class ModelResult:                                                                                                                                                                  │
│     name: str                       # "xgboost" or "random_forest"                                                                                                                  │
│     model: Any                      # trained model object                                                                                                                          │
