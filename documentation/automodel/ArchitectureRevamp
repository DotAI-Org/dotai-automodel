│                                                                                                                                                                                     │
│ def train_all_models(                                                                                                                                                               │
│     X_train, X_test, y_train, y_test, feature_names: list[str]                                                                                                                      │
│ ) -> list[ModelResult]:                                                                                                                                                             │
│                                                                                                                                                                                     │
